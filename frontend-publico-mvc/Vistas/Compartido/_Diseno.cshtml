@inject FrontendPublico.Servicios.IServicioMonedas ServicioMonedas
@inject Microsoft.Extensions.Configuration.IConfiguration Configuracion
@{
    var estaAutenticado = User.Identity?.IsAuthenticated == true;
    decimal saldo = 0;
    if (estaAutenticado)
    {
        try { saldo = await ServicioMonedas.ObtenerSaldoAsync(User.ObtenerUsuarioId()); }
        catch { /* degradación controlada: el saldo simplemente no se muestra */ }
    }
    string ClaseNav(string controlador) =>
        string.Equals((string?)ViewContext.RouteData.Values["controller"], controlador, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active" : "nav-link";
    var urlEstadisticas = Configuracion["Frontends:EstadisticasUrl"] ?? "http://localhost:5080";
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Titulo"] is string titulo ? $"{titulo} — UTN GolMundial 2026" : "UTN GolMundial 2026")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/tema.css" rel="stylesheet" />
    <script>
        // Aplica el tema guardado (o el preferido del sistema) antes de pintar, para evitar parpadeo
        (function () {
            var guardado = localStorage.getItem("tema");
            var preferido = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
            document.documentElement.setAttribute("data-bs-theme", guardado || preferido);
        })();
    </script>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top barra-navegacion">
        <div class="container-xl">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Inicio" asp-action="Indice">
                <span class="logo-marca"><i class="bi bi-trophy-fill"></i></span>
                <span class="texto-marca">UTN GOL<span class="text-success">APUESTAS</span></span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                    aria-controls="menuPrincipal" aria-expanded="false" aria-label="Abrir menú">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="@ClaseNav("Calendario")" asp-controller="Calendario" asp-action="Indice"><i class="bi bi-calendar-event me-1"></i>Partidos</a></li>
                    <li class="nav-item"><a class="@ClaseNav("Posiciones")" asp-controller="Posiciones" asp-action="Indice"><i class="bi bi-trophy me-1"></i>Posiciones</a></li>
                    <li class="nav-item"><a class="@ClaseNav("Estadisticas")" asp-controller="Estadisticas" asp-action="Indice"><i class="bi bi-bar-chart me-1"></i>Estadísticas</a></li>
                    <li class="nav-item"><a class="@ClaseNav("Ranking")" asp-controller="Ranking" asp-action="Indice"><i class="bi bi-star me-1"></i>Ranking</a></li>
                    <li class="nav-item"><a class="@ClaseNav("Predicciones")" asp-controller="Predicciones" asp-action="Indice"><i class="bi bi-lightning-charge me-1"></i>Predecir</a></li>
                    @if (estaAutenticado)
                    {
                        <li class="nav-item"><a class="@ClaseNav("Billetera")" asp-controller="Billetera" asp-action="Indice"><i class="bi bi-wallet2 me-1"></i>Billetera</a></li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button type="button" id="botonTema" class="btn btn-sm btn-contorno-suave" title="Cambiar tema" aria-label="Cambiar tema">
                        <i class="bi bi-moon-stars"></i>
                    </button>
                    @if (estaAutenticado)
                    {
                        <span class="insignia-monedas" title="Saldo de UTNGolCoin">
                            <i class="bi bi-coin"></i> @saldo.ToString("0.##") <small>UGC</small>
                        </span>
                        <span class="text-body-secondary small d-none d-lg-inline">Hola, @User.ObtenerNombre()</span>
                        <form asp-controller="Cuenta" asp-action="Cerrar" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-contorno-suave">
                                <i class="bi bi-box-arrow-right me-1"></i>Salir
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-contorno-suave" href="@urlEstadisticas">Solo estadísticas</a>
                        <a class="btn btn-sm btn-contorno-suave" asp-controller="Cuenta" asp-action="Iniciar">Iniciar sesión</a>
                        <a class="btn btn-sm btn-success fw-bold" asp-controller="Cuenta" asp-action="Registro">
                            <i class="bi bi-person-plus me-1"></i>Registrarse
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="contenido-principal">
        <div class="container-xl">
            <partial name="_Alertas" />
            @RenderBody()
        </div>
    </main>

    <footer class="pie-pagina">
        <div class="container-xl d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span><i class="bi bi-trophy-fill text-success me-1"></i>Portal de apuestas — registro obligatorio para predecir</span>
            <a class="small" href="@urlEstadisticas">Volver al portal de estadísticas (invitado)</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tema.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
