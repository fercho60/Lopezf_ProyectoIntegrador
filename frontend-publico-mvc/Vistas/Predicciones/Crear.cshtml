@model ModeloCrearPrediccion
@{
    ViewData["Titulo"] = "Crear predicción";
    var partido = Model.Partido;
}

<a asp-controller="Calendario" asp-action="Detalle" asp-route-id="@Model.PartidoId" class="btn btn-sm btn-contorno-suave mb-3">
    <i class="bi bi-arrow-left me-1"></i>Volver al partido
</a>

<div class="tarjeta tarjeta-formulario" style="max-width:560px">
    <h1 class="titulo-pagina fs-3 text-center mb-1">Predicción 1X2</h1>

    @if (partido is not null)
    {
        <p class="text-center text-body-secondary mb-4">
            @partido.SeleccionLocal.Bandera @partido.SeleccionLocal.Nombre
            <strong class="mx-1">vs</strong>
            @partido.SeleccionVisitante.Bandera @partido.SeleccionVisitante.Nombre
            <br />
            <small><i class="bi bi-clock me-1"></i>Cierra el @partido.FechaHora.ToString("dd/MM/yyyy 'a las' HH:mm")</small>
        </p>

        <form asp-action="Crear" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="PartidoId" />

            <fieldset class="mb-4">
                <legend class="form-label fs-6">Pronóstico</legend>
                <div class="row g-2">
                    <div class="col-4 opcion-pronostico">
                        <input type="radio" asp-for="Pronostico" value="@Pronostico.Local" id="pronosticoLocal" />
                        <label for="pronosticoLocal">
                            <div class="bandera">@partido.SeleccionLocal.Bandera</div>
                            <div class="small">@partido.SeleccionLocal.Nombre</div>
                            <div class="cuota">@partido.Cuotas.Local.ToString("0.0#")</div>
                        </label>
                    </div>
                    <div class="col-4 opcion-pronostico">
                        <input type="radio" asp-for="Pronostico" value="@Pronostico.Empate" id="pronosticoEmpate" />
                        <label for="pronosticoEmpate">
                            <div class="bandera">🤝</div>
                            <div class="small">Empate</div>
                            <div class="cuota">@partido.Cuotas.Empate.ToString("0.0#")</div>
                        </label>
                    </div>
                    <div class="col-4 opcion-pronostico">
                        <input type="radio" asp-for="Pronostico" value="@Pronostico.Visitante" id="pronosticoVisitante" />
                        <label for="pronosticoVisitante">
                            <div class="bandera">@partido.SeleccionVisitante.Bandera</div>
                            <div class="small">@partido.SeleccionVisitante.Nombre</div>
                            <div class="cuota">@partido.Cuotas.Visitante.ToString("0.0#")</div>
                        </label>
                    </div>
                </div>
                <span asp-validation-for="Pronostico" class="text-danger small"></span>
            </fieldset>

            <div class="mb-4">
                <label asp-for="Monto" class="form-label d-flex justify-content-between">
                    <span>Monto en UTNGolCoin</span>
                    <span class="text-body-secondary">Disponible: <strong class="text-warning">@Model.SaldoDisponible.ToString("0.##") UGC</strong></span>
                </label>
                <input asp-for="Monto" class="form-control" type="number" step="0.5" min="1" />
                <span asp-validation-for="Monto" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 fw-bold">
                <i class="bi bi-lightning-charge me-1"></i>Confirmar predicción
            </button>
            <p class="text-center text-body-secondary small mt-3 mb-0">
                Solo se admite una predicción por partido y no puede modificarse después de confirmada.
            </p>
        </form>
    }
    else
    {
        <div class="alert alert-danger mb-0">El partido indicado no está disponible.</div>
    }
</div>
