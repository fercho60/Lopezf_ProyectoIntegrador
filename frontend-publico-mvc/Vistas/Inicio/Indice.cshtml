@model ModeloInicio
@{
    ViewData["Titulo"] = "Inicio";
}

<section class="heroe mb-4">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <span class="insignia-estado en-juego mb-3"><span class="punto-vivo"></span>MUNDIAL 2026 · EE. UU. · MÉXICO · CANADÁ</span>
            <h1 class="mt-3">Predice el Mundial<br /><span class="text-success">con UTNGolCoin</span></h1>
            <p class="text-body-secondary fs-5 mb-4">
                Estadísticas del torneo más predicciones 1X2. El registro es obligatorio para apostar.
                Si solo quieres consultar el calendario, usa el portal de estadísticas como invitado.
            </p>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Cuenta" asp-action="Registro" class="btn btn-success btn-lg fw-bold">
                        <i class="bi bi-person-plus me-1"></i>Regístrate y recibe 10 UGC
                    </a>
                    <a asp-controller="Calendario" asp-action="Indice" class="btn btn-lg btn-contorno-suave">
                        Explorar como invitado
                    </a>
                </div>
            }
            else
            {
                <a asp-controller="Predicciones" asp-action="Indice" class="btn btn-success btn-lg fw-bold">
                    <i class="bi bi-lightning-charge me-1"></i>Mis predicciones
                </a>
            }
        </div>
    </div>
</section>

@if (Model.EstadisticasNoDisponibles)
{
    <div class="alert alert-warning">
        <i class="bi bi-plug me-2"></i>El servicio de estadísticas no está disponible en este momento.
        El calendario y las posiciones volverán a mostrarse cuando se restablezca la conexión.
    </div>
}
else
{
    @if (Model.PartidosEnJuego.Any())
    {
        <h2 class="titulo-pagina fs-3 mb-3"><span class="acento">●</span> En juego ahora</h2>
        <div class="row g-3 mb-4">
            @foreach (var partido in Model.PartidosEnJuego)
            {
                <div class="col-md-6 col-xl-4">
                    <partial name="_TarjetaPartido" model="partido" />
                </div>
            }
        </div>
    }

    <h2 class="titulo-pagina fs-3 mb-3">Próximos partidos</h2>
    <div class="row g-3 mb-4">
        @foreach (var partido in Model.ProximosPartidos)
        {
            <div class="col-md-6 col-xl-3">
                <partial name="_TarjetaPartido" model="partido" />
            </div>
        }
    </div>
}

<div class="row g-3">
    <div class="col-lg-6">
        <div class="tarjeta">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="titulo-pagina fs-4 mb-0">Top del ranking</h2>
                <a asp-controller="Ranking" asp-action="Indice" class="small">Ver completo <i class="bi bi-chevron-right"></i></a>
            </div>
            @if (Model.MonedasNoDisponibles)
            {
                <p class="text-body-secondary mb-0"><i class="bi bi-plug me-1"></i>El servicio UTNGolCoin no está disponible por el momento.</p>
            }
            else
            {
                <table class="table tabla-gol">
                    <tbody>
                        @foreach (var entrada in Model.TopRanking)
                        {
                            <tr>
                                <td class="fw-bold" style="width:2.5rem">@entrada.Posicion</td>
                                <td><span class="avatar-usuario me-2">@entrada.Iniciales</span>@entrada.NombreUsuario</td>
                                <td class="text-end text-warning fw-bold">@entrada.Saldo.ToString("0.##") UGC</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="tarjeta h-100">
            <h2 class="titulo-pagina fs-4 mb-3">¿Cómo participar?</h2>
            <ol class="mb-0 d-flex flex-column gap-2">
                <li><strong>Regístrate</strong> y recibe 10 UTNGolCoin de bienvenida.</li>
                <li>Elige un partido <strong>programado</strong> y crea tu predicción 1X2.</li>
                <li>Al registrarse el resultado oficial, los aciertos cobran <strong>monto × cuota</strong>.</li>
                <li>¿Saldo en cero? Recibes <strong>1 UGC diaria</strong> al iniciar sesión para seguir jugando.</li>
            </ol>
        </div>
    </div>
</div>
