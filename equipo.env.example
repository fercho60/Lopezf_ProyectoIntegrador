# Copiar a equipo.env y editar solo este archivo al cambiar de red:
#   cp equipo.env.example equipo.env
#
# equipo.env NO se sube a git (cada máquina tiene el suyo).
# make run y make stack leen estas variables.

# --- Repos hermanos usados por make stack ---
# Si conservas las cuatro carpetas como hermanas, no configures estas rutas.
# GUACALES_REPO=/ruta/GuacalesA_ProyectoIntegrador
# UTNGOLCOIN_REPO=/ruta/SantacruzMayra_Proyecto_Integrador
# ADMIN_REPO=/ruta/PumaJoel_ProyectoIntegrador/FrontendAdministrativo

# --- Backends nativos ---
URL_GUACALES=http://localhost:18080/demo/api/v1/
URL_UTNGOLCOIN=http://localhost:5001/api/

# Laboratorio / LAN (ejemplo; descomenta y ajusta mañana):
# URL_GUACALES=http://172.28.114.120:8080/demo/api/v1/
# URL_UTNGOLCOIN=http://172.28.114.129:5001/api/

# false = APIs reales | true = datos ficticios sin backends
# make stack siempre fuerza false al lanzar los frontends.
USAR_SIMULADO=false

# --- Frontends ---
# Local:
BIND_EST=localhost:5080
BIND_APU=localhost:5081
BIND_ADMIN=localhost:5203
LISTEN=0.0.0.0

# Dos PCs distintas en LAN (ejemplo):
# BIND_EST=172.28.114.135:5080
# BIND_APU=172.28.114.136:5081

# --- Bases locales aisladas en .stack/data ---
PG_PORT=15432
PG_DATABASE=guacales_db
PG_USER=postgres
PG_PASSWORD=postgres

MYSQL_PORT=13306
MYSQL_DATABASE=utngolcoin_db
MYSQL_USER=utngolcoin
MYSQL_PASSWORD=utngolcoin

# --- WildFly 39 y driver JDBC (se descargan en .stack/tools si faltan) ---
WILDFLY_VERSION=39.0.1.Final
POSTGRES_JDBC_VERSION=42.7.8
WILDFLY_HTTP_PORT=18080
WILDFLY_MANAGEMENT_PORT=19990
